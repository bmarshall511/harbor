{
  "name": "@harbor/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0"
  },
  "dependencies": {
    "@harbor/types": "workspace:*",
    "@prisma/adapter-pg": "^6.0.0",
    "@prisma/client": "^6.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@harbor/eslint-config": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
