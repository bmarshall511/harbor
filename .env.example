# =============================================================================
# Harbor — Environment Variables
# =============================================================================
# All secrets (Dropbox, AI keys) are configured in the Settings UI
# and stored in an encrypted database table — NOT in env vars.

# Database
# Both local and cloud deployments should use the same Supabase database
# so metadata, archives, and settings stay in sync everywhere.
# See README.md for how to set up Supabase and find these URLs.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Session secret (use the same value on local and Vercel)
HARBOR_SESSION_SECRET="change-me-in-production"

# Deployment mode: "local" (desktop) or "cloud" (Vercel)
HARBOR_DEPLOYMENT_MODE="local"

# Vercel only: protects cron endpoints from unauthorized access
# CRON_SECRET=""
