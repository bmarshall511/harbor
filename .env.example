# =============================================================================
# Harbor — Environment Variables
# =============================================================================
# Only secrets, infrastructure, and runtime bootstrap go here.
# Product configuration (auth mode, AI features, preview settings, etc.)
# is managed in the Harbor UI via Settings → stored in the database.

# -----------------------------------------------------------------------------
# Deployment Mode
# -----------------------------------------------------------------------------
# "local"  — Full features: local filesystem archives, file watcher, ffmpeg
#            preview generation, metadata JSON on disk. For desktop/self-hosted.
# "cloud"  — Dropbox-only: no local filesystem, metadata written to Dropbox
#            via API, previews via Dropbox thumbnail API, cron-based sync.
#            For Vercel / serverless deployments.
HARBOR_DEPLOYMENT_MODE="local"

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
# Local: use the Docker Postgres container (same value for both)
# Cloud (Supabase): DATABASE_URL = pooled (port 6543), DIRECT_URL = direct (port 5432)
DATABASE_URL="postgresql://harbor:harbor_dev@localhost:5433/harbor?schema=public"
DIRECT_URL="postgresql://harbor:harbor_dev@localhost:5433/harbor?schema=public"
REDIS_URL="redis://localhost:6380"

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------
# Session signing secret (generate a random 64-char string for production)
HARBOR_SESSION_SECRET="change-me-in-production"

# -----------------------------------------------------------------------------
# Note: Dropbox and AI API keys are configured in the Settings UI
# and stored in an encrypted database table — NOT in env vars.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Runtime Bootstrap (only needed before the database is available)
# -----------------------------------------------------------------------------
HARBOR_PORT=3000
HARBOR_HOST="localhost"

# -----------------------------------------------------------------------------
# Vercel Cron Secret (cloud mode only)
# -----------------------------------------------------------------------------
# Protects cron endpoints from unauthorized access. Set to a random string.
# Vercel sends this as Authorization: Bearer <secret> on cron invocations.
CRON_SECRET=""
