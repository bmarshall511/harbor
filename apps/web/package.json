    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-window": "^1.8.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
